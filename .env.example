APP_NAME="Claude Demo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8120

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ----- Database (Postgres service) -----
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=claude_demo
DB_USERNAME=claude
DB_PASSWORD=secret

# ----- Session / Cache / Queue (Redis service) -----
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ----- Mail (Mailpit service) -----
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.test"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================================================
# DOCKER HOST PORTS & FRONTEND
# ==============================================================================

# The container always serves on 80 internally; APP_HOST_PORT is the host port
# it's published on. Keep it equal to the port in APP_URL above.
APP_HOST_PORT=8120
# Vite dev-server port. Published 1:1 (host == container) and used by the
# browser for assets/HMR — just change this one value. See vite.config.ts.
VITE_HOST_PORT=5173
# Browser-facing Vite host. `localhost` works with no /etc/hosts edits.
VITE_DEV_SERVER_HOST=localhost
# Mailpit web UI host port (maps to the catcher's internal 8025).
MAILPIT_HOST_PORT=8125

# Exposed to the browser by Vite.
VITE_APP_NAME="${APP_NAME}"
